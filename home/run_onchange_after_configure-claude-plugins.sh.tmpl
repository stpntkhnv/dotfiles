#!/bin/bash
{{ if and .setup_claude .setup_dotnet_skills -}}
set -euo pipefail

# Install the official .NET agent skills plugin (dotnet/skills): C# LSP
# via the Roslyn language server plus core .NET skills. The plugin only
# declares the LSP config — the server itself runs through `dnx`, which
# ships with the .NET 10+ SDK.

claude_bin="$(command -v claude || echo "$HOME/.npm-global/bin/claude")"

if ! command -v dotnet &>/dev/null; then
    echo "WARNING: dotnet SDK not found; the C# language server will not start until it is installed."
fi

if ! "$claude_bin" plugin marketplace list 2>/dev/null | grep -q "dotnet-agent-skills\|dotnet/skills"; then
    echo "Adding dotnet/skills plugin marketplace..."
    "$claude_bin" plugin marketplace add dotnet/skills
fi

if ! "$claude_bin" plugin list 2>/dev/null | grep -qE '(^|[[:space:]])dotnet@dotnet-agent-skills'; then
    echo "Installing dotnet plugin (C# LSP + core .NET skills)..."
    "$claude_bin" plugin install dotnet@dotnet-agent-skills
fi
{{- else -}}
exit 0
{{- end }}
