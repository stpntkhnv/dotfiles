{{- /* Single source of truth for MCP server definitions, rendered as a
       JSON object keyed by server name. Consumed today by the Claude Code
       user-scope sync script; reuse it for ~/.codex/config.toml when Codex
       gets MCP servers too. Browser automation uses the system chromium:
       /usr/bin/chromium exists on the host and is installed in containers
       by 01-install-packages. */ -}}
{{- $servers := dict -}}
{{- if .setup_azure -}}
{{-   $_ := set $servers "azure" (dict
        "type" "stdio"
        "command" "npx"
        "args" (list "-y" "@azure/mcp@latest" "server" "start")) -}}
{{- end -}}
{{- /* One server instance per ADO organization. PAT auth per the official
       docs: --authentication pat + PERSONAL_ACCESS_TOKEN env holding
       base64("<email>:<pat>"). */ -}}
{{- if .setup_ado -}}
{{-   $token := printf "%s:%s" .ado_email .ado_pat | b64enc -}}
{{-   range $org := splitList "," .ado_orgs -}}
{{-     $org = trim $org -}}
{{-     if $org -}}
{{-       $_ := set $servers (printf "azureDevOps-%s" $org) (dict
            "type" "stdio"
            "command" "npx"
            "args" (list "-y" "@azure-devops/mcp" $org "--authentication" "pat")
            "env" (dict "PERSONAL_ACCESS_TOKEN" $token)) -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{- if .setup_context7 -}}
{{-   $c7args := list "-y" "@upstash/context7-mcp" -}}
{{-   if .context7_api_key -}}
{{-     $c7args = concat $c7args (list "--api-key" .context7_api_key) -}}
{{-   end -}}
{{-   $_ := set $servers "context7" (dict
        "type" "stdio"
        "command" "npx"
        "args" $c7args) -}}
{{- end -}}
{{- if .setup_playwright -}}
{{-   $_ := set $servers "playwright" (dict
        "type" "stdio"
        "command" "npx"
        "args" (list "-y" "@playwright/mcp@latest" "--executable-path" "/usr/bin/chromium")) -}}
{{- end -}}
{{- toJson $servers -}}
