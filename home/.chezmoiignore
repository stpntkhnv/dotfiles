# Optional-feature install scripts gate themselves on their setup_* flag
# (rendering to `exit 0` when disabled), so they are not listed here.
# Plain helper files still need flag-based ignores. Container-only flags
# are forced to false on the host by .chezmoi.toml.tmpl, so these lines
# cover the host automatically.
{{ if not .setup_ziti }}
bin/update-ziti-hosts.sh
{{ end }}

# bin/util-linux-fix.sh is fetched by distrobox init_hooks from raw URL, no
# need to deploy it into ~/bin on either side.
bin/util-linux-fix.sh
